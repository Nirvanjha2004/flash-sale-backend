// Prisma Schema for Flash Sale System
// Location: shared/database/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PAID
  EXPIRED
  FAILED
}

model User {
  id        String  @id @default(uuid())
  email     String  @unique
  name      String?
  orders    Order[]
}

model Order {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  productId     String
  quantity      Int
  totalAmount   Decimal
  status        OrderStatus @default(PENDING)
  paymentLink   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  expiresAt     DateTime    // Used by Expiry Server for TTL logic
}
